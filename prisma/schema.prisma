// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  cards     Card[]
  fuelLogs  FuelLog[]

  @@map("users")
}

model MainArea {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  subAreas     SubArea[]
  cards        Card[]
  fuelLogs     FuelLog[]
  areaHistory  CardAreaHistory[]

  @@map("main_areas")
}

model SubArea {
  id          String   @id @default(cuid())
  name        String
  parentAreaId String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  parentArea  MainArea @relation(fields: [parentAreaId], references: [id], onDelete: Cascade)
  cards       Card[]
  fuelLogs    FuelLog[]
  areaHistory CardAreaHistory[]

  @@unique([name, parentAreaId])
  @@map("sub_areas")
}

model Card {
  id            String   @id @default(cuid())
  cardNumber    String   @unique
  identification String?
  areaId        String
  subAreaId     String?
  userId        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  area          MainArea  @relation(fields: [areaId], references: [id], onDelete: Cascade)
  subArea       SubArea?  @relation(fields: [subAreaId], references: [id], onDelete: SetNull)
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fuelLogs     FuelLog[]
  areaHistory  CardAreaHistory[]

  @@map("cards")
}

model FuelLog {
  id          String   @id @default(cuid())
  date        DateTime
  amount      Float
  pricePerGallon Float
  totalCost   Float
  gallons     Float
  odometer    Int?
  location    String?
  description String?
  remito      String?
  status      String   @default("IMPORTED")
  mainAreaId  String?
  subAreaId   String?
  cardNumber  String?  // Store card number for PENDING rows
  userId      String
  cardId      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  card        Card?     @relation(fields: [cardId], references: [id], onDelete: SetNull)
  mainArea    MainArea? @relation(fields: [mainAreaId], references: [id], onDelete: SetNull)
  subArea     SubArea?  @relation(fields: [subAreaId], references: [id], onDelete: SetNull)

  @@map("fuel_logs")
  @@unique([remito])
}

model ImportSettings {
  id           String   @id @default(cuid())
  name         String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  mappings     ImportMapping[]

  @@map("import_settings")
}

model ImportMapping {
  id            String   @id @default(cuid())
  internalField  String
  rawColumnName String
  importSettings String
  settingsId    String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  settings      ImportSettings @relation(fields: [settingsId], references: [id], onDelete: Cascade)

  @@map("import_mappings")
}

model CardAreaHistory {
  id          String    @id @default(cuid())
  cardId      String
  mainAreaId  String
  subAreaId   String?
  validFrom   DateTime
  validTo     DateTime?
  createdAt   DateTime  @default(now())

  card        Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  mainArea    MainArea  @relation(fields: [mainAreaId], references: [id])
  subArea     SubArea?  @relation(fields: [subAreaId], references: [id])

  @@map("card_area_history")
}
